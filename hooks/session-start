#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "$ROOT"

if command -v node >/dev/null 2>&1; then
  node scripts/dci/bootstrap.mjs --json
else
  printf '{"additionalContext":"DCI bootstrap requires Node.js >=18. Install Node, then run dci bootstrap --json."}\n'
fi
