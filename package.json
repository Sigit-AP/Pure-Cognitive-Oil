{
  "name": "deterministic-cognitive-infrastructure",
  "version": "1.6.0",
  "description": "Portable cognitive infrastructure plugin for AI agent harnesses.",
  "private": false,
  "type": "module",
  "bin": {
    "dci": "bin/dci.mjs"
  },
  "files": [
    "bin/",
    "hooks/",
    "references/",
    "scripts/dci/",
    "scripts/link_references.py",
    "skills/",
    "SKILL.md",
    "README.md",
    "PRD.md",
    "plugin.json",
    "tsconfig.json"
  ],
  "keywords": [
    "ai-agent",
    "cognitive-infrastructure",
    "agent-framework",
    "skills",
    "reasoning",
    "verification"
  ],
  "license": "MIT",
  "scripts": {
    "dci:index": "tsx scripts/dci/index.ts",
    "dci:audit": "tsx scripts/dci/audit.ts",
    "dci:context": "tsx scripts/dci/context.ts",
    "dci:bootstrap": "tsx scripts/dci/bootstrap.ts",
    "dci:bootstrap:json": "tsx scripts/dci/bootstrap.ts --json",
    "dci:validate": "tsx scripts/dci/validate.ts",
    "dci:parity": "tsx scripts/dci/parity.ts",
    "dci:readiness": "tsx scripts/dci/parity.ts",
    "dci:all": "npm run dci:index && npm run dci:audit && npm run dci:context && npm run dci:validate && npm run dci:readiness",
    "test:dci": "bash tests/dci/run-all.sh",
    "test": "npm run dci:all && npm run test:dci"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
