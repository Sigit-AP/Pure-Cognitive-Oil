{
  "name": "pure-cognitive-oil",
  "version": "1.6.1-direct-use.1",
  "description": "Pure Cognitive Oil: portable cognitive infrastructure plugin and autonomous optimizer command for AI agent harnesses, with direct AI model boot support.",
  "private": false,
  "type": "module",
  "main": ".opencode/plugins/pco.js",
  "bin": {
    "pco": "bin/pco.mjs"
  },
  "files": [
    ".opencode/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "bin/",
    "hooks/",
    "references/",
    "scripts/pco/",
    "scripts/link_references.py",
    "skills/",
    "SKILL.md",
    "AI_MODEL_BOOT.md",
    "README.md",
    "plugin.json",
    "docs/",
    "examples/",
    "tests/fixtures/",
    "tests/ai-benchmarks/rubrics/",
    "tests/ai-benchmarks/tasks/",
    "tsconfig.json",
    "efficiency/",
    "scripts/pco/mode-selector.mjs",
    "scripts/pco/compact-index.mjs",
    "scripts/pco/resource-budget.py"
  ],
  "keywords": [
    "agent-framework",
    "ai-agent",
    "autonomous-optimizer",
    "cognitive-infrastructure",
    "direct-ai-model-boot",
    "pco",
    "pure-cognitive-oil",
    "reasoning",
    "skills",
    "verification"
  ],
  "license": "MIT",
  "scripts": {
    "pco:agentic-auto": "node scripts/pco/agentic-auto.mjs",
    "pco:all": "npm run pco:index && npm run pco:audit && npm run pco:context && npm run pco:lifecycle && npm run pco:validate && npm run pco:readiness",
    "pco:audit": "tsx scripts/pco/audit.ts",
    "pco:bootstrap": "node scripts/pco/bootstrap.mjs",
    "pco:bootstrap:json": "node scripts/pco/bootstrap.mjs --json",
    "pco:context": "tsx scripts/pco/context.ts",
    "pco:healthcheck": "node scripts/pco/healthcheck.mjs",
    "pco:index": "tsx scripts/pco/index.ts",
    "pco:lifecycle": "node scripts/pco/lifecycle.mjs",
    "pco:parity": "tsx scripts/pco/parity.ts",
    "pco:readiness": "tsx scripts/pco/parity.ts",
    "pco:references": "node references/runtime/pco-reference-runtime.mjs",
    "pco:references:core": "node references/core/runtime.mjs",
    "pco:runtime-audit": "node scripts/pco/runtime-audit.mjs",
    "pco:scorecard": "node scripts/pco/scorecard.mjs",
    "pco:tools": "node references/tools/reference-toolkit.mjs list",
    "pco:tools:quality": "node references/quality-safety/tools/quality-safety-toolkit.mjs list",
    "pco:tools:workflows": "node references/workflows/tools/workflows-toolkit.mjs list",
    "pco:validate": "tsx scripts/pco/validate.ts",
    "pco:package-validation": "node scripts/pco/package-check.mjs",
    "pco:skill-check": "node scripts/pco/skill-check.mjs",
    "pco:package-check": "node scripts/pco/package-check.mjs",
    "pco:reference-quality": "node scripts/pco/reference-quality.mjs",
    "pco:evidence-graph": "node scripts/pco/evidence-graph.mjs",
    "pco:professional-parity-check": "node scripts/pco/professional-parity-check.mjs",
    "pack:dry": "npm pack --dry-run",
    "validate:release": "npm test && npm run pco:validate && npm run pco:readiness && npm run pco:runtime-audit && npm run pco:healthcheck && npm run pco:scorecard && npm run pco:skill-check && npm run pco:package-check && npm run pco:reference-quality && npm run pco:professional-parity-check",
    "test": "node scripts/pco/install-smoke.mjs",
    "test:pco": "npm test",
    "pco:mode": "node scripts/pco/mode-selector.mjs",
    "pco:compact-index": "node scripts/pco/compact-index.mjs",
    "pco:budget": "python scripts/pco/resource-budget.py",
    "pco:efficient-check": "node scripts/pco/install-smoke.mjs",
    "pco:install-check": "node scripts/pco/install-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": {
    "name": "Sigit-AP",
    "url": "https://github.com/Sigit-AP"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sigit-AP/Pure-Cognitive-Oil.git"
  },
  "homepage": "https://github.com/Sigit-AP/Pure-Cognitive-Oil#readme",
  "bugs": {
