{
  "name": "deterministic-cognitive-infrastructure",
  "version": "1.6.1",
  "description": "Portable cognitive infrastructure plugin for AI agent harnesses.",
  "private": false,
  "type": "module",
  "main": ".opencode/plugins/dci.js",
  "bin": {
    "dci": "bin/dci.mjs"
  },
  "files": [
    ".opencode/",
    ".claude-plugin/",
    ".codex-plugin/",
    ".cursor-plugin/",
    "AGENTS.md",
    "CLAUDE.md",
    "GEMINI.md",
    "bin/",
    "hooks/",
    "references/",
    "scripts/dci/",
    "scripts/link_references.py",
    "tests/dci/",
    "skills/",
    "SKILL.md",
    "README.md",
    "plugin.json",
    "docs/",
    "tsconfig.json"
  ],
  "keywords": [
    "ai-agent",
    "cognitive-infrastructure",
    "agent-framework",
    "skills",
    "reasoning",
    "verification"
  ],
  "license": "MIT",
  "scripts": {
    "dci:index": "tsx scripts/dci/index.ts",
    "dci:audit": "tsx scripts/dci/audit.ts",
    "dci:context": "tsx scripts/dci/context.ts",
    "dci:bootstrap": "node scripts/dci/bootstrap.mjs",
    "dci:bootstrap:json": "node scripts/dci/bootstrap.mjs --json",
    "dci:validate": "tsx scripts/dci/validate.ts",
    "dci:parity": "tsx scripts/dci/parity.ts",
    "dci:readiness": "tsx scripts/dci/parity.ts",
    "dci:references": "node references/runtime/dci-reference-runtime.mjs",
    "dci:tools": "node references/tools/reference-toolkit.mjs list",
    "dci:tools:workflows": "node references/workflows/tools/workflows-toolkit.mjs list",
    "dci:tools:quality": "node references/quality-safety/tools/quality-safety-toolkit.mjs list",
    "dci:agentic-auto": "node scripts/dci/agentic-auto.mjs",
    "dci:runtime-audit": "node scripts/dci/runtime-audit.mjs",
    "dci:references:core": "node references/core/runtime.mjs",
    "dci:all": "npm run dci:index && npm run dci:audit && npm run dci:context && npm run dci:lifecycle && npm run dci:validate && npm run dci:readiness",
    "test:dci": "bash tests/dci/run-all.sh",
    "test": "npm run dci:all && npm run test:dci",
    "dci:healthcheck": "node scripts/dci/healthcheck.mjs",
    "dci:scorecard": "node scripts/dci/scorecard.mjs",
    "dci:lifecycle": "node scripts/dci/lifecycle.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
